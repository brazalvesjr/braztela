<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.braztela" name="BRAZTELA" version="1.0.0" provider-name="Braz Junior">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="pt_BR">BRAZTELA - Streaming Premium</summary>
        <summary lang="en_GB">BRAZTELA - Premium Streaming</summary>
        <description lang="pt_BR">BRAZTELA e uma plataforma de streaming premium com TV ao vivo, filmes, series, 20 servidores configuraveis, autenticacao individual por cliente e controle parental.</description>
        <description lang="en_GB">BRAZTELA is a premium streaming platform with live TV, movies, series, 20 configurable servers, individual client authentication and parental control.</description>
        <platform>all</platform>
        <license>MIT</license>
        <source>https://github.com/brazalvesjr/braztela</source>
        <forum>https://github.com/brazalvesjr/braztela/issues</forum>
        <website>https://github.com/brazalvesjr/braztela</website>
        <email>contato@braztela.com</email>
        <news>v1.0.0 - Lancamento oficial do BRAZTELA</news>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
